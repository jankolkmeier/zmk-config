#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/matrix-transform.h>

/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "BETEM All Keys";
        transform = <&matrix_transform0>;
        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0  150  (-500)   200   400>
            , <&key_physical_attrs 100 100  100  100  (-500)   200   400>
            , <&key_physical_attrs 100 100  200   25  (-300)   300   375>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400   25       0     0     0>
            , <&key_physical_attrs 100 100  500   35       0     0     0>
            , <&key_physical_attrs 100 100  850   35       0     0     0>
            , <&key_physical_attrs 100 100  950   25       0     0     0>
            , <&key_physical_attrs 100 100 1050    0       0     0     0>
            , <&key_physical_attrs 100 100 1150   25     300  1150   375>
            , <&key_physical_attrs 100 100 1250  100     500  1275   400>
            , <&key_physical_attrs 100 100 1350  150     500  1275   400>
            , <&key_physical_attrs 100 100    0  250  (-500)   200   400>
            , <&key_physical_attrs 100 100  100  200  (-500)   200   400>
            , <&key_physical_attrs 100 100  200  125  (-300)   300   375>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  125       0     0     0>
            , <&key_physical_attrs 100 100  500  135       0     0     0>
            , <&key_physical_attrs 100 100  850  135       0     0     0>
            , <&key_physical_attrs 100 100  950  125       0     0     0>
            , <&key_physical_attrs 100 100 1050  100       0     0     0>
            , <&key_physical_attrs 100 100 1150  125     300  1150   375>
            , <&key_physical_attrs 100 100 1250  200     500  1275   400>
            , <&key_physical_attrs 100 100 1350  250     500  1275   400>
            , <&key_physical_attrs 100 100  100  300  (-500)   200   400>
            , <&key_physical_attrs 100 100  200  225  (-300)   300   375>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  225       0     0     0>
            , <&key_physical_attrs 100 100  500  235       0     0     0>
            , <&key_physical_attrs 100 100  850  235       0     0     0>
            , <&key_physical_attrs 100 100  950  225       0     0     0>
            , <&key_physical_attrs 100 100 1050  200       0     0     0>
            , <&key_physical_attrs 100 100 1150  225     300  1150   375>
            , <&key_physical_attrs 100 100 1250  300     500  1275   400>
            , <&key_physical_attrs 100 100  375  350       0     0     0>
            , <&key_physical_attrs 100 100  500  350     600   475   250>
            , <&key_physical_attrs 100 100  600  350    1200   525   375>
            , <&key_physical_attrs 100 100  750  350 (-1200)   925   375>
            , <&key_physical_attrs 100 100  850  350  (-600)   975   250>
            , <&key_physical_attrs 100 100  975  350       0     0     0>
            ;
    };

	matrix_transform0: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <10>;
		rows = <4>;
        map = <
        RC(3,0) RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)                   RC(0,9) RC(0,8) RC(0,7) RC(0,6) RC(0,5) RC(3,5) 
        RC(3,1) RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)                   RC(1,9) RC(1,8) RC(1,7) RC(1,6) RC(1,5) RC(3,6) 
                RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)                   RC(2,9) RC(2,8) RC(2,7) RC(2,6) RC(2,5) 
                                        RC(3,2) RC(3,3) RC(3,4)   RC(3,9) RC(3,8) RC(3,7)
        >;
	};
};